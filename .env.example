UID=1001
GID=1001

# DeepLake настройки
DEEPLAKE_PORT=6543
DEEPLAKE_TOKEN=  # Оставьте пустым для локальной разработки
DEEPLAKE_LOGGING_LEVEL=INFO
DEEPLAKE_DATASET_PATH=/root/deeplake_storage

OLLAMA_MODEL=hodza/cotype-nano-1.5-unofficial:latest
OLLAMA_EMBED_MODEL=bge-m3
OLLAMA_REQUEST_TIMEOUT=900
OLLAMA_CONTEXT_WINDOW=4096
#16384
OLLAMA_CONTEXT_LENGTH=2048

OLLAMA_NUM_THREADS=8

FLOWISE_DOMAIN=flowise.dl-blog.ru

OLLAMA_CLOUDE_MODEL=qwen3-coder:480b-cloud

CLOUDE_MODEL=1
