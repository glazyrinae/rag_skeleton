UID=1001
GID=1001

# DeepLake настройки
DEEPLAKE_PORT=6543
DEEPLAKE_TOKEN=  # Оставьте пустым для локальной разработки
DEEPLAKE_LOGGING_LEVEL=INFO
DEEPLAKE_DATASET_PATH=/root/deeplake_storage

# Выбор backend для IndexRegistry:
# - deeplake (текущий default)
# - postgres (через PostgresIndexRegistry)
RAG_INDEX_BACKEND=deeplake

# PostgreSQL для векторного индекса и FTS/BM25-like ретривера
PG_HOST=postgres
PG_PORT=5432
PG_DATABASE=postgres
PG_USER=postgres
PG_PASSWORD=postgres
PGVECTOR_SCHEMA=public
PGVECTOR_TABLE_NAME=core_vector_index
PGVECTOR_EMBED_DIM=1024
PG_BM25_TABLE_NAME=core_bm25_chunks
PG_BM25_TS_CONFIG=russian
BM25_SIMILARITY_TOP_K=10

OLLAMA_MODEL=hodza/cotype-nano-1.5-unofficial:latest
OLLAMA_EMBED_MODEL=bge-m3
OLLAMA_REQUEST_TIMEOUT=900
OLLAMA_CONTEXT_WINDOW=4096
#16384
OLLAMA_CONTEXT_LENGTH=2048

OLLAMA_NUM_THREADS=8
OLLAMA_DNS_1=1.1.1.1
OLLAMA_DNS_2=8.8.8.8
OLLAMA_DNS_3=9.9.9.9
OLLAMA_DNS_TIMEOUT_SEC=5
OLLAMA_DNS_ATTEMPTS=5
# Аварийный обход DNS для Ollama Cloud (если Docker DNS в серверной сети нестабилен)
OLLAMA_COM_IP=34.36.133.15

FLOWISE_DOMAIN=flowise.dl-blog.ru

OLLAMA_CLOUDE_MODEL=qwen3-coder:480b-cloud

CLOUDE_MODEL=1
